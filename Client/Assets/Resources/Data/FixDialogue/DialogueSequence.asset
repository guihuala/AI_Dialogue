  sequence:
  - speaker: "\u72EC\u767D"
    content: "\u4E09\u4E2A\u6708\u7684\u6691\u5047\u683C\u5916\u6F2B\u957F\uFF0C\u6211\u65E0\u6240\u4E8B\u4E8B\u8DB4\u5728\u684C\u5B50\u4E0A\u7FFB\u770B\u624B\u673A\u3002"
    mood: "\u5E73\u9759"
  - speaker: "\u72EC\u767D"
    content: "\u624B\u4E2D\u7684\u624B\u673A\u55E1\u55E1\u9707\u4E2A\u4E0D\u505C\uFF0C\u5FAE\u4FE1\u7684\u6D88\u606F\u4E00\u76F4\u5F39\u51FA\u6765\u59A8\u788D\u89C6\u7EBF\u3002"
    mood: "\u5E73\u9759"
  - speaker: "\u72EC\u767D"
    content: "\u6211\u4E0D\u8010\u70E6\u5730\u70B9\u8FDB\u53BB\uFF0C\u662F\u8F85\u5BFC\u5458\u5728\u5168\u9662\u5927\u7FA4\u91CC\u53D1\u7684\u300A\u8FCE\u65B0\u5206\u53D1\u610F\u5411\u8868.xls\u300B\u3002\u6587\u4EF6\u52A0\u8F7D\u7684\u5706\u5708\u8F6C\u4E86\u4E24\u5708\uFF0C\u5C4F\u5E55\u4E0A\u8DF3\u51FA\u4E00\u884C\u5B57\uFF1A\u201C\u8BF7\u5404\u4F4D\u540C\u5B66\u81EA\u884C\u8054\u7CFB\uFF0C\u5EFA\u7ACB4\u4EBA\u5C0F\u7EC4\u540E\u4E0A\u62A5\u3002\u201D"
    mood: "\u5E73\u9759"
  - speaker: "\u72EC\u767D"
    content: "\u89C6\u7EBF\u5F80\u4E0B\u79FB\uFF0C\u6211\u770B\u7740\u540D\u5355\u91CC\u90A3\u51E0\u4E2A\u540D\u5B57\uFF0C\u540D\u5B57\u8FB9\u4E0A\u662F\u5BF9\u5E94\u7684\u5FAE\u4FE1\u53F7\u3002\u5149\u662F\u770B\u540D\u5B57\uFF0C\u5B9E\u5728\u5F88\u96BE\u60F3\u8C61\u5BF9\u65B9\u662F\u4EC0\u4E48\u6837\u7684\u4EBA\u3002\u6211\u8FD8\u5728\u7EA0\u7ED3\u4E2D\uFF0C\u624B\u673A\u5F39\u51FA\u6765\u4E00\u8FDE\u4E32\u9A8C\u8BC1\u6D88\u606F\u3002"
    mood: "\u5E73\u9759"
  - speaker: "\u624B\u673A\u754C\u9762"
    content: "\u201C\u65B0\u7684\u670B\u53CB\u201D\u5217\u8868\u51FA\u73B0 6 \u4E2A\u7EA2\u70B9\u3002"
    mood: "\u5E73\u9759"
  - speaker: "\u72EC\u767D"
    content: "\u7B2C\u4E00\u4E2A\u8DF3\u51FA\u7684\u662F\u5510\u68A6\u742A\u3002\u5934\u50CF\u662F\u552F\u7F8E\u80CC\u5F71\u7167\u3002\u670B\u53CB\u5708\u7B7E\u540D\u662F\uFF1A\u201C\u4EE5\u7231\u4E4B\u540D\uFF0C\u5954\u8D74\u5C71\u6D77\u201D\u3002\u53D1\u7684\u5185\u5BB9\u5927\u591A\u662F\u65C5\u6E38\u7167\uFF0C\u8FD8\u6709\u53D1\u4E0A\u4ECE\u5C0F\u7EA2\u4E66\u4E0A\u6284\u6765\u7684\u914D\u5957\u6587\u6848\u3002"
    mood: "\u5E73\u9759"
  - speaker: "\u5FAE\u4FE1 - \u5510\u68A6\u742A"
    content: "\u201C\u54C8\u55BD\u54C8\u55BD\uFF01\u662F\u9646\u9648\u540C\u5B66\u5417\uFF1F\u6211\u662F\u5510\u68A6\u742A~\u4EE5\u540E\u8BF7\u591A\u5173\u7167\u5440\uFF01[\u53EF\u7231][\u53EF\u7231]\u201D"
    mood: "\u5E73\u9759"
  - speaker: "\u5FAE\u4FE1 - \u9646\u9648\u5B89\u7136"
    content: "\u201C\u4F60\u597D\uFF0C\u6211\u662F\u9646\u9648\u5B89\u7136\uFF0C\u8BF7\u591A\u5173\u7167\u3002\u201D"
    mood: "\u5E73\u9759"
  - speaker: "\u72EC\u767D"
    content: "\u9646\u9648\uFF1F\u4ECE\u6765\u6CA1\u4EBA\u8FD9\u4E48\u53EB\u6211\uFF0C\u633A\u65B0\u5947\u7684\u3002\u4F46\u662F\u88AB\u8FD9\u4E48\u53EB\u83AB\u540D\u5176\u5999\u89C9\u5F97\u6709\u4E9B\u4E0D\u81EA\u5728\u3002\u5979\u770B\u4E0A\u53BB\u548C\u6211\u7684\u5FD7\u8DA3\u76F8\u5DEE\u5F88\u5927\uFF0C\u6211\u4EEC\u80FD\u804A\u5F97\u6765\u5427..."
    mood: "\u5E73\u9759"
  - speaker: "\u72EC\u767D"
    content: "\u7B2C\u4E8C\u4E2A\u662F\u674E\u4E00\u8BFA\u3002\u5934\u50CF\u662F\u6A31\u6843\u5C0F\u4E38\u5B50\u3002\u670B\u53CB\u5708\u8BBE\u7F6E\u4E86\u201C\u4EC5\u4E09\u5929\u53EF\u89C1\u201D\uFF0C\u7B7E\u540D\u680F\u662F\u4E00\u53E5\u751F\u786C\u7684\u82F1\u6587\uFF1A\"Efficiency
      is life.\""
    mood: "\u5E73\u9759"
  - speaker: "\u5FAE\u4FE1 - \u674E\u4E00\u8BFA"
    content: "\u201C\u4F60\u597D\uFF0C\u6211\u662F\u674E\u4E00\u8BFA\u3002\u5982\u679C\u662F\u5173\u4E8E\u5BBF\u820D\u5206\u914D\u7684\u4E8B\uFF0C\u5EFA\u8BAE\u6211\u4EEC\u5148\u786E\u8BA4\u4E00\u4E0B\u4F5C\u606F\u65F6\u95F4\u662F\u5426\u5339\u914D\uFF0C\u6211\u4E0D\u5E0C\u671B\u4E92\u76F8\u5E72\u6270\u3002\u201D"
    mood: "\u5E73\u9759"
  - speaker: "\u5FAE\u4FE1 - \u9646\u9648\u5B89\u7136"
    content: "\u201C\u4F60\u597D\uFF0C\u6211\u662F\u9646\u9648\u5B89\u7136\uFF0C\u6211\u6574\u7406\u597D\u4F5C\u606F\u8868\u53D1\u7ED9\u4F60\u5427\u3002\u201D"
    mood: "\u5E73\u9759"
  - speaker: "\u72EC\u767D"
    content: "\u597D\u7A92\u606F\uFF0C\u8FD8\u6CA1\u89C1\u9762\u5C31\u5DF2\u7ECF\u5F00\u59CB\u7ACB\u89C4\u77E9\u4E86\uFF0C\u5E94\u8BE5\u662F\u5F88\u4E25\u8083\u5F88\u8BA4\u771F\u7684\u4EBA\u5427\u3002\u4E5F\u633A\u597D\u7684\u5427\uFF0C\u81F3\u5C11\u4E0D\u4F1A\u6709\u88AB\u5435\u5230\u7684\u60C5\u51B5\u5427\uFF0C\u8FD8\u4F1A\u5E26\u52A8\u5927\u5BB6\u7684\u5B66\u4E60\u70ED\u60C5\u3002"
    mood: "\u5E73\u9759"
  - speaker: "\u72EC\u767D"
    content: "\u8FD9\u4E2A\u53EB\u6797\u98D2\u7684...... \u5934\u50CF\u662F\u4E00\u5F20\u9ED1\u767D\u6A21\u7CCA\u7684Livehouse\u73B0\u573A\u56FE\uFF0C\u5168\u662F\u566A\u70B9\u3002\u6CA1\u6709\u7B7E\u540D\uFF0C\u751A\u81F3\u8FDE\u540D\u5B57\u90A3\u4E00\u680F\u90FD\u53EA\u586B\u4E86\u4E2A\u53E5\u53F7\u3002"
    mood: "\u5E73\u9759"
  - speaker: "\u5FAE\u4FE1 - \u6797\u98D2"
    content: "\u201C\u3002\u201D\uFF08\u901A\u8FC7\u4E86\u670B\u53CB\u9A8C\u8BC1\uFF09"
    mood: "\u5E73\u9759"
  - speaker: "\u5FAE\u4FE1 - \u9646\u9648\u5B89\u7136"
    content: "\u201C\u6797\u98D2\u540C\u5B66\uFF1F\u6211\u662F\u9646\u9648\u5B89\u7136\u3002\u201D"
    mood: "\u5E73\u9759"
  - speaker: "\u72EC\u767D"
    content: "\u8FD9\u662F\uFF1F\u5979\u770B\u8D77\u6765\u5B8C\u5168\u4E0D\u60F3\u548C\u6211\u5BF9\u8BDD\uFF0C\u4E0D\u77E5\u9053\u4E3A\u4EC0\u4E48\u8FD8\u6765\u4E3B\u52A8\u52A0\u6211\u3002\u770B\u6211\u5934\u50CF\u6BD4\u8F83\u987A\u773C\u5417\uFF1F"
    mood: "\u5E73\u9759"
  - speaker: "\u72EC\u767D"
    content: "\u9648\u96E8\u5A77\u3002\u6211\u770B\u5230\u5979\u5728\u65B0\u751F\u7FA4\u91CC\u7684\u53D1\u8A00\uFF0C\u5979\u5E94\u8BE5\u662F\u53D1\u8A00\u6700\u79EF\u6781\u7684\u90A3\u4E00\u6CE2\u5427\u3002\u5934\u50CF\u662F\u8FD1\u671F\u706B\u7684\u7EBF\u6761\u5C0F\u72D7\uFF0C\u670B\u53CB\u5708\u91CC\u53D1\u4E86\u5F88\u591A\u5979\u6536\u85CF\u7684\u6CE1\u6CE1\u739B\u7279\u76F2\u76D2\u7167\u7247\u3002"
    mood: "\u5E73\u9759"
  - speaker: "\u5FAE\u4FE1 - \u9648\u96E8\u5A77"
    content: "\u201C\u5B89\u7136\u4F60\u597D\uFF01\u6211\u662F\u9648\u96E8\u5A77\u3002\u6211\u4E5F\u5728\u8054\u7CFB\u5176\u4ED6\u51E0\u4F4D\u540C\u5B66\uFF0C\u6B63\u5728\u62C9\u4E00\u4E2A\u2018\u5BDD\u5BA4\u9884\u5907\u7FA4\u2019\uFF0C\u7A0D\u540E\u9EBB\u70E6\u4F60\u8FDB\u7FA4\u6539\u4E00\u4E0B\u5907\u6CE8\uFF08\u59D3\u540D+\u4E13\u4E1A\uFF09\uFF0C\u65B9\u4FBF\u5927\u5BB6\u7EDF\u7B79\u5B89\u6392\u3002\u201D"
    mood: "\u5E73\u9759"
  - speaker: "\u5FAE\u4FE1 - \u9646\u9648\u5B89\u7136"
    content: "\u201C\u96E8\u5A77\u4F60\u597D\uFF0C\u73B0\u5728\u5C31\u62C9\u7FA4\u804A\uFF0C\u6211\u548C\u5176\u4ED6\u51E0\u4F4D\u540C\u5B66\u804A\u804A\u518D\u51B3\u5B9A\u5427\uFF1F\u201D"
    mood: "\u5E73\u9759"
  - speaker: "\u72EC\u767D"
    content: "\u201C\u7EDF\u7B79\u5B89\u6392\u201D...\u8BF6...\u53EF\u6211\u8FD8\u6CA1\u8BF4\u8981\u548C\u5979\u4E00\u8D77\u554A\uFF0C\u7ADF\u7136\u81EA\u4F5C\u4E3B\u5F20\u5E2E\u6211\u51B3\u5B9A\u4E86\u5417\u3002\u611F\u89C9\u662F\u4E2A\u5F88\u9760\u8C31\u5F88\u4F1A\u6765\u4E8B\u7684\u4EBA\uFF0C\u597D\u50CF\u5904\u5904\u90FD\u8981\u7BA1\u70B9\u4EC0\u4E48\u4E8B\uFF1F"
    mood: "\u5E73\u9759"
  - speaker: "\u72EC\u767D"
    content: "\u82CF\u6D45\u3002\u5927\u6982\u5728\u901A\u8FC7\u4E86\u5341\u5206\u949F\u540E\u624D\u56DE\u6D88\u606F\u3002\u5934\u50CF\u662F\u4E2A\u4E0D\u77E5\u9053\u662F\u52A8\u753B\u8FD8\u662F\u6E38\u620F\u7684\u89D2\u8272\uFF0C\u4E00\u4E2A\u767D\u53D1\u84DD\u77B3\u7684\u5C11\u5973\uFF1F\u670B\u53CB\u5708\u4EC0\u4E48\u90FD\u6CA1\u53D1\u8FC7\uFF0C\u53EA\u6709\u4E00\u5F20\u4E8C\u6B21\u5143\u624B\u529E\u56FE\u4F5C\u4E3A\u80CC\u666F\u3002"
    mood: "\u5E73\u9759"
  - speaker: "\u5FAE\u4FE1 - \u82CF\u6D45"
    content: "\u201C\u4F60\u597D......\u6211\u662F\u82CF\u6D45\u3002\u201D *\u8868\u60C5\u5305.jpg\uFF08\u4E00\u53EA\u8EB2\u5728\u5899\u89D2\u7684\u5C0F\u732B\uFF09*
