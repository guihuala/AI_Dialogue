  - speaker: "\u72EC\u767D"
    content: "\u2026\u2026\u5173\u6CE8\u70B9\u597D\u795E\u5947\uFF0C\u5B8C\u5168\u6CA1\u6709\u5BD2\u6684\u7684\u610F\u601D\u3002\u6BD4\u8D77\u6211\uFF0C\u5979\u4F3C\u4E4E\u66F4\u5173\u5FC3\u7F51\u7EBF\u7684\u4F4D\u7F6E\uFF0C\u662F\u4E2A\u5B9E\u7528\u4E3B\u4E49\u8005\u3002"
