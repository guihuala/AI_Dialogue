    mood: "\u5E73\u9759"
  - speaker: "\u72EC\u767D"
    content: "\u8F85\u5BFC\u5458\u770B\u4E0A\u53BB\u662F\u4E2A\u6CA1\u5927\u6211\u4EEC\u51E0\u5C81\u7684\u5E74\u8F7B\u5C0F\u4F19\uFF0C\u4E2A\u5B50\u4E0D\u9AD8\uFF0C\u6D88\u7626\uFF0C\u5927\u5927\u7684\u773C\u775B\u70AF\u70AF\u6709\u795E\u3002\u5F88\u96BE\u60F3\u8C61\u8FD9\u4E2A\u770B\u4E0A\u53BB\u80FD\u548C\u6211\u4EEC\u6253\u6210\u4E00\u7247\u7684\u4EBA\uFF0C\u8BF4\u8BDD\u5DF2\u7ECF\u5F88\u6709\u5B98\u5A01\u3002"
    mood: "\u5E73\u9759"
  - speaker: "\u8F85\u5BFC\u5458"
    content: "\u201C\u8003\u91CF\u5927\u5BB6\u8FC7\u4E86\u5927\u5B66\u4E5F\u4E0D\u8981\u61C8\u6020\uFF0C\u4E0D\u8981\u6302\u79D1\uFF0C\u4E0D\u8981\u60F9\u4E8B\u3002\u4F60\u4EEC\u53EF\u4EE5\u8C08\u604B\u7231\uFF0C\u53EF\u4EE5\u5076\u5C14\u71AC\u591C\uFF0C\u5076\u5C14\u653E\u7EB5\u4E00\u4E0B\u3002\u6BD5\u7ADF\u5927\u5B66\u751F\u6D3B\u53EA\u6709\u4E00\u6B21\u3002\u4F46\u662F\uFF0C\u6211\u518D\u91CD\u590D\u4E00\u904D\uFF0C\u5373\u4F7F\u8FDB\u4E86\u5927\u5B66\u4E5F\u8981\u597D\u597D\u5B66\u4E60\u3002\u201D"
    mood: "\u5E73\u9759"
  - speaker: "\u8F85\u5BFC\u5458"
    content: "\u201C\u597D\uFF0C\u73B0\u5728\u5F00\u59CB\u81EA\u6211\u4ECB\u7ECD\uFF0C\u5927\u5BB6\u968F\u4FBF\u8BB2\uFF0C\u4EC0\u4E48\u90FD\u53EF\u4EE5\u8BB2\uFF0C\u653E\u677E\u4E00\u70B9\u3002\u4ECE\u7B2C\u4E00\u6392\u5F00\u59CB\uFF0C\u6BCF\u4E2A\u4EBA\u9650\u65F6\u4E24\u5206\u949F\u3002\u201D"
    mood: "\u5E73\u9759"
  - speaker: "\u72EC\u767D"
    content: "\u9648\u96E8\u5A77\u96F7\u5389\u98CE\u884C\uFF0C\u8FD8\u6CA1\u8F6E\u5230\u5979\uFF0C\u5979\u5C31\u5DF2\u7ECF\u628A\u8170\u633A\u5F97\u7B14\u76F4\u3002\u8F6E\u5230\u5979\u65F6\uFF0C\u5979\u8FC5\u901F\u7AD9\u8D77\uFF0C\u5411\u56DB\u5468\u70B9\u5934\u81F4\u610F\uFF0C\u751A\u81F3\u8FD8\u8981\u8FC7\u9EA6\u514B\u98CE\u3002"
    mood: "\u5E73\u9759"
  - speaker: "\u9648\u96E8\u5A77"
    content: "\u201C\u620F\u8001\u5E08\u597D\uFF0C\u5404\u4F4D\u540C\u5B66\u597D\u3002\u6211\u662F\u8BBE\u8BA1\u7CFB\u7684\u9648\u96E8\u5A77\u3002\u6211\u5462\uFF0C\u6BD4\u8F83\u559C\u6B22social\uFF0C\u5927\u5BB6\u6709party\u8BB0\u5F97\u9080\u8BF7\u6211\u54C8\u3002\u8FD8\u6709\uFF0C\u6211\u559C\u6B22\u76F2\u76D2\uFF0C\u6211\u7279\u522B\u559C\u6B22XX\u7CFB\u5217\uFF0C\u4F60\u4EEC\u6709\u8C01\u4E5F\u53BB\u62BD\u76F2\u76D2\u5417\uFF1F...\u201D"
    mood: "\u5E73\u9759"
  - speaker: "\u72EC\u767D"
    content: "\u5979\u7528\u4E86\u8FD9\u79CD\u6700\u5C34\u5C2C\u7684\u95EE\u7B54\u5F0F\u81EA\u6211\u4ECB\u7ECD\u3002\u7136\u800C\u5E76\u6CA1\u6709\u591A\u5C11\u4EBA\u56DE\u5E94\uFF0C\u611F\u89C9\u5979\u81EA\u5DF1\u4E5F\u6709\u4E9B\u5C34\u5C2C\uFF0C\u8BF4\u5B8C\u5C31\u4F4E\u5934\u4E0B\u53F0\u4E86\u3002"
    mood: "\u5E73\u9759"
  - speaker: "\u72EC\u767D"
    content: "\u4E0D\u8FC7\u6211\u539F\u4EE5\u4E3A\u5979\u4F1A\u8BF4\u5F88\u591A\u5BA2\u5957\u8BDD\u6765\u8BA8\u597D\u8F85\u5BFC\u5458\uFF0C\u5B9E\u9645\u4E0A\u5E76\u6CA1\u6709\u3002\u523B\u677F\u5370\u8C61\u4E0D\u53EF\u53D6\u554A\u3002"
    mood: "\u5E73\u9759"
  - speaker: "\u5510\u68A6\u742A"
    content: "\u201CHi \u5927\u5BB6~ \u6211\u662F\u5510\u68A6\u742A\u3002\u6211\u662F\u53CC\u5B50\u5EA7\uFF0C\u5E73\u65F6\u8D85\u7EA7\u559C\u6B22\u63A2\u5E97\u548CShopping\uFF01\u8FD9\u91CC\u6709\u559C\u6B22\u6253\u738B\u8005\u8363\u8000\u7684\u59D0\u59B9\u5417\uFF1F\u6216\u8005\u662F\u559C\u6B22\u5403\u9EC4\u725B\u7684\uFF1F\u4E00\u5B9A\u8981\u627E\u6211\u5FAE\u4FE1\u54E6\uFF01\u6211\u4EEC\u53EF\u4EE5\u4E00\u8D77\u7EA6\uFF01\u7231\u4F60\u4EEC\u54DF~\u201D"
    mood: "\u5E73\u9759"
