  - speaker: "\u5FAE\u4FE1 - \u8D75\u946B"
    content: "\u201C\u6765\u4E86\u3002\u201D \u201C\u4F60\u662F\u53EB\u5B89\u7136\u5417\uFF1F\u597D\u957F\u3002\u201D
      \u201C\u95EE\u4E00\u4E0B\uFF0C\u4F60\u77E5\u9053\u90A3\u4E2A\u5BBF\u820D\u7684\u7F51\u53E3\u5728\u684C\u5B50\u5DE6\u8FB9\u8FD8\u662F\u53F3\u8FB9\u5417\uFF1F\u201D"
