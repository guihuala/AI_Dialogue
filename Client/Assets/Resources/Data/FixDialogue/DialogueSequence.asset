    mood: "\u5E73\u9759"
  - speaker: "\u72EC\u767D"
    content: "\u597D\u7EAF\u6B63\u7684\u4E8C\u6B21\u5143\u554A\uFF01\u4E0D\u8FC7\u4E5F\u4E0D\u5947\u602A\uFF0C\u6BD5\u7ADF\u6211\u5934\u50CF\u4E5F\u662F\u4E8C\u6B21\u5143\u56FE\u7247\uFF0C\u53EF\u80FD\u662F\u540C\u7C7B\u76F8\u5438\uFF1F"
