# ==============================================================================
# 🐍 Python Server (Backend)
# ==============================================================================
# Python 编译文件和缓存
Server/__pycache__/
Server/*.py[cod]
Server/*$py.class

# 虚拟环境 (根据你的命名习惯)
Server/venv/
Server/.venv/
Server/env/

# 环境变量与密钥 (⚠️ 非常重要，防止 API Key 泄露)
Server/.env

# 运行时的数据库与存档数据
# 这些数据随游戏运行频繁变化，且体积可能很大，不应提交到仓库
Server/data/chroma_db/
Server/data/*.json

# 仅保留 data 目录结构，但不提交内容（可选，如果你希望保留目录）
!Server/data/.gitkeep

# VS Code / IDE 配置 (Python侧)
Server/.vscode/
Server/.idea/


# ==============================================================================
# 🎮 Unity Client (Frontend)
# 基于你上传的文件修改，添加了 'Client/' 前缀以匹配新的目录结构
# ==============================================================================

# 核心库文件夹 (由 Unity 自动生成)
Client/[Ll]ibrary/
Client/[Tt]emp/
Client/[Oo]bj/
Client/[Bb]uild/
Client/[Bb]uilds/
Client/[Ll]ogs/
Client/[Uu]ser[Ss]ettings/

# 内存捕获与录制数据 (通常很大且包含敏感数据)
Client/[Mm]emoryCaptures/
Client/[Rr]ecordings/

# 插件相关的生成文件
Client/[Aa]ssets/Plugins/Editor/JetBrains*
Client/[Aa]ssets/AssetStoreTools*

# IDE 生成的项目文件
Client/.vs/
Client/.gradle/
Client/ExportedObj/
Client/.consulo/
# 下面这些后缀规则通常可以全局匹配，不需要加前缀，但也为了整洁列在这里
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity 生成的元数据 (Crash reports 等)
*.pidb.meta
*.pdb.meta
*.mdb.meta
sysinfo.txt
crashlytics-build.properties

# 构建产物
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Addressables 和 StreamingAssets 的临时文件
Client/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
Client/[Aa]ssets/[Ss]treamingAssets/aa.meta
Client/[Aa]ssets/[Ss]treamingAssets/aa/*

# ==============================================================================
# 🖥️ OS / General
# ==============================================================================
.DS_Store
Thumbs.db